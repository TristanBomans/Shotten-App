{
  "name": "shotten-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.6",
  "scripts": {
    "build": "bun run build:cf",
    "build:cf": "cd pwa && bun run build:cf && rm -rf ../.open-next && cp -R .open-next ../.open-next",
    "deploy": "bun run build:cf",
    "lint": "eslint",
    "mobile:install": "bun install --cwd mobile",
    "mobile:dev": "bun run --cwd mobile dev",
    "mobile:start": "bun run --cwd mobile start",
    "mobile:android": "bun run --cwd mobile android",
    "mobile:ios": "bun run --cwd mobile ios",
    "preview": "bun run build:cf",
    "preinstall": "npx only-allow bun"
  }
}
